<Window x:Class="LicenseDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License SDK Demo" Height="720" Width="560"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="FpLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,6,0,1"/>
        </Style>
        <Style x:Key="FpValue" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Background" Value="#2d2d2d"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Window.Background>
        <SolidColorBrush Color="#111111"/>
    </Window.Background>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- License key input + action buttons -->
            <GroupBox Grid.Row="0" Header="许可证操作" Foreground="#aaa" BorderBrush="#333" Margin="0,0,0,12">
                <StackPanel Margin="8">
                    <TextBlock Style="{StaticResource FpLabel}">License Key</TextBlock>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="31*"/>
                            <ColumnDefinition Width="118*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LicenseKeyBox" Background="#1a1a1a" Foreground="#e0e0e0"
                             BorderBrush="#444" Padding="4,4" FontFamily="Consolas"
                             Text="XXXX-XXXX-XXXX-XXXX" Grid.ColumnSpan="2"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                            <Button Content="激活" Click="Activate_Click" Margin="0,0,6,0"/>
                            <Button Content="验证" Click="Verify_Click" Margin="0,0,6,0"/>
                            <Button Content="解绑" Click="Deactivate_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- Status banner -->
            <Border Grid.Row="1" x:Name="StatusBorder" Background="#1a2a1a" BorderBrush="#2a4a2a"
                BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                HorizontalAlignment="Stretch">
                <TextBlock x:Name="StatusText" Foreground="#6fcf6f" FontSize="13"
                       Text="— 正在读取许可证状态…" TextWrapping="Wrap"/>
            </Border>

            <!-- Hardware fingerprint display -->
            <GroupBox Grid.Row="2" Header="本机硬件指纹（只读）" Foreground="#aaa" BorderBrush="#333">
                <StackPanel Margin="8">
                    <TextBlock Style="{StaticResource FpLabel}">主板 / SMBIOS UUID（权重 32）</TextBlock>
                    <TextBox x:Name="FpMotherboard" Style="{StaticResource FpValue}"/>

                    <TextBlock Style="{StaticResource FpLabel}">硬盘序列号 — 所有磁盘，任一匹配得分（权重 28）</TextBlock>
                    <TextBox x:Name="FpDisk" Style="{StaticResource FpValue}"/>

                    <TextBlock Style="{StaticResource FpLabel}">BIOS 序列号（权重 18）</TextBlock>
                    <TextBox x:Name="FpBios" Style="{StaticResource FpValue}"/>

                    <TextBlock Style="{StaticResource FpLabel}">C: 磁盘卷序列号 — kernel32（权重 10）</TextBlock>
                    <TextBox x:Name="FpVolumeSerial" Style="{StaticResource FpValue}"/>

                    <TextBlock Style="{StaticResource FpLabel}">CPU ID（权重 6）</TextBlock>
                    <TextBox x:Name="FpCpu" Style="{StaticResource FpValue}"/>

                    <TextBlock Style="{StaticResource FpLabel}">Windows MachineGuid（权重 4）</TextBlock>
                    <TextBox x:Name="FpMachineGuid" Style="{StaticResource FpValue}"/>

                    <TextBlock Style="{StaticResource FpLabel}">Windows ProductId（权重 1，仅辅助）</TextBlock>
                    <TextBox x:Name="FpWindowsProductId" Style="{StaticResource FpValue}" TextChanged="FpWindowsProductId_TextChanged"/>

                    <TextBlock Style="{StaticResource FpLabel}">物理网卡 MAC — 所有网卡，任一匹配得分（权重 1）</TextBlock>
                    <TextBox x:Name="FpMac" Style="{StaticResource FpValue}"/>

                    <TextBlock Style="{StaticResource FpLabel}">指纹哈希（SHA-256）</TextBlock>
                    <TextBox x:Name="FpHash" Style="{StaticResource FpValue}"/>
                </StackPanel>
            </GroupBox>

            <TextBlock Grid.Row="3" Foreground="#555" FontSize="10" Margin="0,10,0,0"
                   Text="License SDK Demo"/>
        </Grid>
    </ScrollViewer>
</Window>
